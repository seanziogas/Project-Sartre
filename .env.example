# Shared application state
DATABASE_URL=postgresql://sartre:change-me@localhost:5432/sartre
SARTRE_CLIENTS_DIR=./clients

# Runner
SARTRE_TICK_MS=30000
SARTRE_HEALTH_PORT=3001
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com
# OTEL_EXPORTER_OTLP_HEADERS={"Authorization":"Bearer <deployment-secret>"}
# SARTRE_MODULE_DEPS=/absolute/path/to/deployment-adapter.mjs

# Portal authentication (the proxy must strip caller-supplied identity headers)
SARTRE_TRUSTED_AUTH_PROXY=true
SARTRE_PORTAL_ACCESS_FILE=/absolute/path/to/portal-access.json
SARTRE_PUBLIC_BASE_URL=https://sartre.example.com

# Preferred: a versioned keyring. Values are 32 random bytes, base64-encoded.
# Keep an old key in the map until `npm run rotate-credentials` reports all envelopes migrated.
# SARTRE_CREDENTIAL_ENCRYPTION_KEYS={"2026-07":"<deployment-secret>"}
# SARTRE_CREDENTIAL_CURRENT_KEY_ID=2026-07
# Legacy single-key deployments remain readable during migration:
# SARTRE_CREDENTIAL_ENCRYPTION_KEY=<legacy-deployment-secret>

# Required only for live LLM-backed execution and Brain copilot.
# ANTHROPIC_API_KEY=<deployment-secret>
# Production model override; defaults to claude-opus-4-8 when unset.
# SARTRE_LLM_MODEL=claude-opus-4-8
