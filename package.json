{
  "name": "sartre",
  "private": true,
  "version": "0.1.0",
  "description": "The Kiln's GTM Operating System — one platform, instanced per client.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b packages/* apps/runner && npm run build --workspace @sartre/ops",
    "test": "vitest run",
    "typecheck": "tsc -b packages/* apps/runner && tsc --noEmit -p apps/ops/tsconfig.json",
    "preflight": "npm run preflight --workspace @sartre/runner",
    "rotate-credentials": "npm run rotate-credentials --workspace @sartre/runner",
    "simulate": "npm run simulate --workspace @sartre/runner",
    "governance": "npm run governance --workspace @sartre/runner --",
    "governance-request": "npm run governance-request --workspace @sartre/runner --",
    "governance-decide": "npm run governance-decide --workspace @sartre/runner --",
    "restore-tenant": "npm run restore-tenant --workspace @sartre/runner --",
    "record-eval": "npm run record-eval --workspace @sartre/runner --",
    "shadow:fake": "node tools/shadow-hologram/run.mjs --fake --synthetic"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
